{
  "uid": "api-n2",
  "title": "API Demo — Diagnostic (N2)",
  "description": "Dashboard de diagnostic — détail par endpoint, saturation système, corrélation logs",
  "tags": ["api", "supervision", "n2", "diagnostic"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
        "query": "label_values(up, job)",
        "current": { "text": "api", "value": "api" },
        "includeAll": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "handler",
        "label": "Endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
        "query": "label_values(http_requests_total{job=\"$job\"}, handler)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Taux d'erreurs 5xx par endpoint",
      "description": "Quel endpoint génère des erreurs serveur ?",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by(handler) (rate(http_requests_total{job=\"$job\", handler=~\"$handler\", status=~\"5..\"}[2m]))",
          "legendFormat": "{{handler}} — 5xx",
          "refId": "A"
        },
        {
          "expr": "sum by(handler) (rate(http_requests_total{job=\"$job\", handler=~\"$handler\", status=~\"4..\"}[2m]))",
          "legendFormat": "{{handler}} — 4xx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "Latence par endpoint (p95)",
      "description": "Quel endpoint est le plus lent ? (SLO global: p95 < 500ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(handler, le) (rate(http_request_duration_seconds_bucket{job=\"$job\", handler=~\"$handler\"}[5m])))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1.0 }]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "thresholds": { "mode": "line", "show": true }
      }
    },
    {
      "id": 3,
      "title": "Répartition du trafic par endpoint",
      "description": "Volume de requêtes par handler sur la fenêtre sélectionnée",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by(handler) (increase(http_requests_total{job=\"$job\", handler=~\"$handler\"}[30m]))",
          "legendFormat": "{{handler}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["percent", "name"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 4,
      "title": "Taux de succès global (SLO)",
      "description": "SLO: ≥ 99,5% de requêtes non-5xx. La ligne rouge = seuil d'alerte.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{job=\"$job\"}[5m])) - sum(rate(http_requests_total{job=\"$job\", status=~\"5..\"}[5m]))) / sum(rate(http_requests_total{job=\"$job\"}[5m])) * 100",
          "legendFormat": "Taux de succès %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 90,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": 0 }, { "color": "orange", "value": 99 }, { "color": "green", "value": 99.5 }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "thresholds": { "mode": "line", "show": true } }
    },
    {
      "id": 5,
      "title": "CPU — utilisation par mode",
      "description": "Décomposition CPU: user, system, idle, iowait",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "avg by(mode) (rate(node_cpu_seconds_total{mode!=\"idle\"}[1m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 6,
      "title": "Mémoire — usage détaillé",
      "description": "Mémoire totale, utilisée, disponible et cache/buffers",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Utilisée",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Disponible",
          "refId": "C"
        },
        {
          "expr": "node_memory_Cached_bytes + node_memory_Buffers_bytes",
          "legendFormat": "Cache+Buffers",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 7,
      "title": "Erreurs métier applicatives",
      "description": "Compteur d'erreurs custom levées par le code applicatif",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by(endpoint, error_type) (rate(api_business_errors_total[2m]))",
          "legendFormat": "{{endpoint}} — {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Utilisateurs actifs simulés",
      "description": "Gauge api_active_users — exemple de métrique custom",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "api_active_users",
          "legendFormat": "active users",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 9,
      "title": "Logs API — corrélation erreurs (Loki)",
      "description": "Logs en ERROR/WARNING de l'API — corrélez avec les pics de métriques ci-dessus",
      "type": "logs",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki-ds" },
      "targets": [
        {
          "expr": "{job=\"api\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
